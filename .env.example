# Server
BASE_URL=http://localhost:8080
SERVER_ADDR=:8080

# Database shards (PostgreSQL DSNs)
DB_SHARD_0_DSN=postgres://urlshortener:secret@localhost:5432/urlshortener?sslmode=disable
DB_SHARD_1_DSN=postgres://urlshortener:secret@localhost:5433/urlshortener?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# GeoIP (MaxMind GeoLite2-Country.mmdb path)
GEOIP_DB_PATH=./data/GeoLite2-Country.mmdb

# Rate limiting (per IP, sliding window)
RATE_LIMIT=100
RATE_BURST=20
RATE_WINDOW_SECONDS=60

# Analytics
ANALYTICS_BUFFER_SIZE=2048
